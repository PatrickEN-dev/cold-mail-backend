# ============================================================
# Coldmail Backend — environment variables (sample)
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---------- Runtime ----------
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# ---------- Database (Supabase Postgres) ----------
# Direct connection (used for migrations / DDL)
DATABASE_URL=postgresql://postgres:password@db.kxgwviiewmnmignqmptu.supabase.co:5432/postgres?schema=public
# Pooled connection for runtime (pgbouncer)
DATABASE_POOL_URL=postgresql://postgres:password@db.kxgwviiewmnmignqmptu.supabase.co:6543/postgres?schema=public&pgbouncer=true

# ---------- Supabase Auth ----------
SUPABASE_URL=https://kxgwviiewmnmignqmptu.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---------- Redis (BullMQ) ----------
REDIS_URL=redis://localhost:6379

# ---------- Webhooks (inbound) ----------
WEBHOOK_HMAC_SECRET=replace-me-with-32-byte-random
UNIPILE_WEBHOOK_SECRET=
ZAPMAIL_WEBHOOK_SECRET=
SMARTLEAD_WEBHOOK_SECRET=

# ---------- Email providers ----------
RESEND_API_KEY=
ZAPMAIL_API_KEY=
SMARTLEAD_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
SES_AWS_ACCESS_KEY_ID=
SES_AWS_SECRET_ACCESS_KEY=
SES_REGION=us-east-1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---------- AI ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ---------- LinkedIn (Unipile) ----------
UNIPILE_API_KEY=
UNIPILE_DSN=

# ---------- Search (RapidAPI) ----------
RAPIDAPI_KEY=

# ---------- Supabase Edge Function ----------
WARMUP_BUDGET_URL=https://kxgwviiewmnmignqmptu.supabase.co/functions/v1/warmup-budget

# ---------- Observability ----------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ---------- Feature flags ----------
DISPATCH_VIA_N8N=false
ENABLE_WARMUP_WORKER=true
ENABLE_SCHEDULES_CRON=true
ENABLE_FOLLOWUPS_CRON=true
