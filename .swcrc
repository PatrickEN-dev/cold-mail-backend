{
  "$schema": "https://swc.rs/schema.json",
  "sourceMaps": true,
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@modules/*": ["src/modules/*"],
      "@infra/*": ["src/infra/*"],
      "@shared/*": ["src/shared/*"]
    },
    "keepClassNames": true,
    "target": "es2023"
  },
  "module": {
    "type": "commonjs"
  }
}
